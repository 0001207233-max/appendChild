<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Atividade 15 - Histórico de Números</title>
    <style>
        body { font-family: Arial, sans-serif; padding: 20px; }
        button { padding: 10px 15px; font-size: 16px; cursor: pointer; }
        #historico {
            margin-top: 15px;
            padding: 15px;
            border: 1px solid #ddd;
            background-color: #f9f9f9;
            max-width: 200px;
            max-height: 300px;
            overflow-y: auto;
            border-radius: 5px;
        }
        .item-numero {
            padding: 5px 10px;
            margin-bottom: 5px;
            background-color: #fff;
            border: 1px solid #eee;
            border-radius: 3px;
            font-weight: bold;
            color: #333;
        }
    </style>
</head>
<body>

    <button id="btnAdicionar">Adicionar Número</button>
    <div id="historico"></div>

    <script src="script.js"></script>
</body>
</html>

<!--JS-->


const btnAdicionar = document.getElementById('btnAdicionar');
const historico = document.getElementById('historico');


let numeroAtual = 1;


btnAdicionar.addEventListener('click', function() {
    
    const novoElemento = document.createElement('div');
    
    
    novoElemento.classList.add('item-numero');
    
   
    novoElemento.textContent = numeroAtual;
    
   
    historico.appendChild(novoElemento);
    
   
    numeroAtual++;
});
