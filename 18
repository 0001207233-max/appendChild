<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Atividade 18 - Sistema de Comentários</title>
    <style>
        body { font-family: Arial, sans-serif; padding: 20px; background-color: #f0f2f5; }
        .caixa-comentario { background: white; padding: 15px; border-radius: 8px; max-width: 500px; box-shadow: 0 1px 2px rgba(0,0,0,0.1); margin-bottom: 20px; }
        textarea { width: 100px; min-width: 96%; height: 60px; padding: 10px; border: 1px solid #ccd0d5; border-radius: 6px; resize: none; font-family: inherit; }
        button { margin-top: 10px; padding: 8px 16px; background-color: #1877f2; color: white; border: none; border-radius: 6px; font-weight: bold; cursor: pointer; }
        button:hover { background-color: #166fe5; }
        #feedComentarios { max-width: 520px; }
        .comentario-item { background: white; padding: 12px; margin-bottom: 10px; border-radius: 8px; box-shadow: 0 1px 2px rgba(0,0,0,0.1); border-left: 4px solid #1877f2; word-wrap: break-word; }
    </style>
</head>
<body>

    <div class="caixa-comentario">
        <textarea id="txtComentario" placeholder="Escreva um comentário..."></textarea>
        <button id="btnPublicar">Publicar Comentário</button>
    </div>

    <div id="feedComentarios"></div>

    <script src="script.js"></script>
</body>
</html>

<!--JS-->


const txtComentario = document.getElementById('txtComentario');
const btnPublicar = document.getElementById('btnPublicar');
const feedComentarios = document.getElementById('feedComentarios');


btnPublicar.addEventListener('click', function() {

    const textoComentario = txtComentario.value.trim();
    
  
    if (textoComentario === '') {
        alert('Por favor, digite algo antes de publicar seu comentário.');
        return;
    }
    
   
    const novoComentario = document.createElement('div');
    
   
    novoComentario.classList.add('comentario-item');
    
   
    novoComentario.textContent = textoComentario;
    
    
    feedComentarios.appendChild(novoComentario);
    
   
    txtComentario.value = '';
    txtComentario.focus();
});
