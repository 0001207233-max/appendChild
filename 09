<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Atividade 9 - Gerenciador de Quadrados</title>
    <style>
        body { font-family: Arial, sans-serif; padding: 20px; }
        button { padding: 8px 12px; cursor: pointer; margin-right: 5px; }
        #areaGrafica {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            border: 2px dashed #bbb;
            padding: 15px;
            margin-top: 15px;
            min-height: 150px;
            max-width: 600px;
            background-color: #fdfdfd;
            border-radius: 5px;
        }
        .quadrado {
            width: 50px;
            height: 50px;
            background-color: #3498db;
            border-radius: 4px;
        }
    </style>
</head>
<body>

    <button id="btnCriar">Criar Quadrado</button>
    <button id="btnRemover">Remover Quadrado</button>
    
    <div id="areaGrafica"></div>

    <script src="script.js"></script>
</body>
</html>

<!--JS-->

const btnCriar = document.getElementById('btnCriar');
const btnRemover = document.getElementById('btnRemover');
const areaGrafica = document.getElementById('areaGrafica');


btnCriar.addEventListener('click', function() {
    const novoQuadrado = document.createElement('div');
    novoQuadrado.classList.add('quadrado');
    areaGrafica.appendChild(novoQuadrado);
});


btnRemover.addEventListener('click', function() {
   
    const ultimoQuadrado = areaGrafica.lastElementChild;
    
  
    if (ultimoQuadrado) {
        areaGrafica.removeChild(ultimoQuadrado);
    } else {
        alert('Não há nenhum quadrado para remover!');
    }
});
