<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Atividade 12 - Lista de Tarefas</title>
    <style>
        body { font-family: Arial, sans-serif; padding: 20px; }
        .input-container { margin-bottom: 15px; }
        input { padding: 8px; margin-right: 5px; width: 250px; }
        button { padding: 8px 12px; cursor: pointer; }
        ul { max-width: 350px; padding-left: 20px; }
        li { padding: 8px; margin-bottom: 5px; background-color: #f8f9fa; border-left: 4px solid #6c757d; border-radius: 3px; list-style-type: none; }
    </style>
</head>
<body>

    <div class="input-container">
        <input type="text" id="inputTarefa" placeholder="Digite uma nova tarefa...">
        <button id="btnAdicionar">Adicionar Tarefa</button>
    </div>

    <ul id="listaTarefas"></ul>

    <script src="script.js"></script>
</body>
</html>

<!--JS-->


const inputTarefa = document.getElementById('inputTarefa');
const btnAdicionar = document.getElementById('btnAdicionar');
const listaTarefas = document.getElementById('listaTarefas');


btnAdicionar.addEventListener('click', function() {
    
    const textoTarefa = inputTarefa.value.trim();
    
   
    if (textoTarefa === '') {
        alert('Por favor, digite uma descrição para a tarefa.');
        return;
    }
    
  
    const novaTarefa = document.createElement('li');
    
   
    novaTarefa.textContent = textoTarefa;
    
   
    listaTarefas.appendChild(novaTarefa);
    
   
    inputTarefa.value = '';
    inputTarefa.focus();
});
