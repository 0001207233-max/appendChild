<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Atividade 3 - Adicionar e Remover</title>
    <style>
        body { font-family: Arial, sans-serif; padding: 20px; }
        .botoes { margin-bottom: 15px; }
        button { margin-right: 10px; padding: 8px 12px; cursor: pointer; }
        #painel {
            border: 1px solid #ccc;
            padding: 15px;
            border-radius: 5px;
            max-width: 400px;
            min-height: 50px;
        }
        p { margin: 5px 0; padding: 5px; background-color: #f0f0f0; border-radius: 3px; }
    </style>
</head>
<body>

    <div class="botoes">
        <button id="btnAdicionar">Adicionar Mensagem</button>
        <button id="btnRemover">Remover Mensagem</button>
    </div>
    
    <div id="painel"></div>

    <script src="script.js"></script>
</body>
</html>


<!--JS-->

const btnAdicionar = document.getElementById('btnAdicionar');
const btnRemover = document.getElementById('btnRemover');
const painel = document.getElementById('painel');


let totalMensagens = 1;


btnAdicionar.addEventListener('click', function() {
    const novaMensagem = document.createElement('p');
    novaMensagem.textContent = `Mensagem de controle nº ${totalMensagens}`;
    painel.appendChild(novaMensagem);
    totalMensagens++;
});


btnRemover.addEventListener('click', function() {
    
    const ultimaMensagem = painel.lastElementChild;
    
   
    if (ultimaMensagem) {
        painel.removeChild(ultimaMensagem);
    } else {
        console.log("Nenhuma mensagem para remover.");
    }
});
