<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Atividade 1 - Mensagens</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            padding: 20px;
        }

        #areaMensagens {
            border: 1px solid #ccc;
            padding: 15px;
            margin-top: 15px;
            border-radius: 5px;
            max-width: 400px;
        }

        p {
            margin: 5px 0;
            color: #333;
        }
    </style>

</head>


<body>

    <button id="btnAdicionar">Adicionar Mensagem</button>
    <div id="areaMensagens"></div>

    <script src="script.js"></script>

</body>

</html>
<--! JS-->


const btnAdicionar = document.getElementById('btnAdicionar');
const areaMensagens = document.getElementById('areaMensagens');


btnAdicionar.addEventListener('click', function() {
    
    const novoParagrafo = document.createElement('p');
    
   
    novoParagrafo.textContent = 'Bem-vindo ao sistema!';
    
   
    areaMensagens.appendChild(novoParagrafo);
});
